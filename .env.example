# 快递助手 ERP 开放平台
KDZS_APP_KEY=
KDZS_APP_SECRET=
# 已有 session 时可以填写以跳过换取步骤；接口签名仍需要 appKey/appSecret
KDZS_SESSION=
KDZS_GATEWAY=https://gw.kuaidizs.cn/open/api
KDZS_TOKEN_URL=http://gw.superboss.cc/api/token

# 首次全量同步起点；建议设为实际开始经营日期
SYNC_START_DATE=2026-01-01
# 订单按修改时间回看 3 天，售后回看 45 天，利润回算 45 天
ORDER_LOOKBACK_DAYS=3
REFUND_LOOKBACK_DAYS=45
PROFIT_LOOKBACK_DAYS=45
PROFIT_DETAIL_LOOKBACK_DAYS=3
KDZS_TRADE_MODIFIED_TIME_TYPE=MODIFIED_TIME
KDZS_TRADE_CREATED_TIME_TYPE=CREATE_TIME

# 仅在每月 15 日及以后结算上月；手工执行 payroll 也遵守该规则
PAYROLL_SETTLEMENT_DAY=15
TIMEZONE=Asia/Shanghai
LOG_LEVEL=info
PORT=3000
SCHEDULER_ENABLED=true
# 新 Base 数据结构迁移完成前保持 false，避免旧映射误写
SYNC_ENABLED=false
HEALTH_INTERVAL_MINUTES=10
